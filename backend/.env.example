APP_ENV=local
DATABASE_URL=postgresql+asyncpg://fotosintesis:fotosintesis@localhost:5432/fotosintesis
OBJECT_STORAGE_BUCKET=fotosintesis-local
MODEL_PROVIDER=mock
VISION_PROVIDER=mock
JUDGE_PROVIDER=mock
SEARCH_PROVIDER=mock
EMBEDDING_PROVIDER=mock
MODEL_PROVIDERS=["mock","mock"]
VISION_PROVIDERS=["mock","mock"]
JUDGE_PROVIDERS=["mock","mock"]
SEARCH_PROVIDERS=["mock","mock"]
OPENAI_API_KEY=
GEMINI_API_KEY=
OPENAI_TEXT_MODEL=gpt-5.4
OPENAI_VISION_MODEL=gpt-5.4
OPENAI_JUDGE_MODEL=gpt-5.4
OPENAI_SEARCH_MODEL=gpt-5.4
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
GEMINI_TEXT_MODEL=gemini-2.5-flash
GEMINI_VISION_MODEL=gemini-2.5-flash
GEMINI_JUDGE_MODEL=gemini-2.5-flash
GEMINI_SEARCH_MODEL=gemini-2.5-flash
# Keep EMBEDDING_DIMENSION aligned with the selected embedding model and existing vector table.
EMBEDDING_DIMENSION=8
LOG_LEVEL=INFO
SESSION_COOKIE_NAME=fotosintesis_session
SESSION_IDLE_TTL_MINUTES=30
SESSION_ABSOLUTE_TTL_DAYS=7
RECOVERY_TOKEN_TTL_MINUTES=30
# Durable background jobs (disabled by default)
JOBS_PRODUCER_ENABLED=false
JOBS_WORKER_ENABLED=false
JOBS_REQUIRED_CONTRACTS=enrich_confirmed_plant:1
JOBS_POLL_INTERVAL_SECONDS=5
JOBS_BATCH_SIZE=10
JOBS_WORKER_CONCURRENCY=5
JOBS_LEASE_DURATION_SECONDS=300
JOBS_LEASE_RENEWAL_INTERVAL_SECONDS=60
JOBS_MAX_ATTEMPTS_DEFAULT=3
JOBS_BACKOFF_BASE_SECONDS=10
JOBS_BACKOFF_CAP_SECONDS=3600
JOBS_SHUTDOWN_DRAIN_SECONDS=30
JOBS_METRICS_HOST=127.0.0.1
JOBS_METRICS_PORT=9100
