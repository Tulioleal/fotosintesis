APP_ENV=local
DATABASE_URL=postgresql+asyncpg://fotosintesis:fotosintesis@localhost:5432/fotosintesis
OBJECT_STORAGE_ENDPOINT=http://localhost:9000
OBJECT_STORAGE_BUCKET=fotosintesis-local
OBJECT_STORAGE_ACCESS_KEY=minioadmin
OBJECT_STORAGE_SECRET_KEY=minioadmin
MODEL_PROVIDER=mock
VISION_PROVIDER=mock
JUDGE_PROVIDER=mock
SEARCH_PROVIDER=mock
EMBEDDING_PROVIDER=mock
OPENAI_API_KEY=
