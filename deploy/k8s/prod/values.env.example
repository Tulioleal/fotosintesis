# Copy to values.env and fill from `tofu output` for infra/opentofu/envs/prod.
NAMESPACE=fotosintesis
APP_ENV=prod
IMAGE_REGISTRY=us-central1-docker.pkg.dev/example-project/fotosintesis
BACKEND_IMAGE_TAG=release-tag
FRONTEND_IMAGE_TAG=release-tag
BACKEND_REPLICAS=2
FRONTEND_REPLICAS=2
FRONTEND_SERVICE_TYPE=ClusterIP
FRONTEND_API_BASE_URL=http://fotosintesis-backend:8000
BACKEND_GCP_SERVICE_ACCOUNT_EMAIL=fotosintesis-backend-prod@example-project.iam.gserviceaccount.com
FRONTEND_GCP_SERVICE_ACCOUNT_EMAIL=fotosintesis-frontend-prod@example-project.iam.gserviceaccount.com
OBJECT_STORAGE_BUCKET=example-fotosintesis-storage
CLOUD_SQL_INSTANCE_CONNECTION_NAME=example-project:us-central1:fotosintesis-prod
CLOUD_SQL_DATABASE_NAME=fotosintesis
MODEL_PROVIDER=openai
VISION_PROVIDER=openai
JUDGE_PROVIDER=openai
SEARCH_PROVIDER=mock
EMBEDDING_PROVIDER=mock
OPENAI_TEXT_MODEL=gpt-5.4
OPENAI_VISION_MODEL=gpt-5.4
OPENAI_JUDGE_MODEL=gpt-5.4
RUNTIME_SECRET_NAME=fotosintesis-runtime
