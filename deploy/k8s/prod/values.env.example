# Copy to values.env and fill from `tofu output` for infra/opentofu/envs/prod.
# BACKEND_IMAGE_TAG and FRONTEND_IMAGE_TAG must be the full 40-character
# Git commit SHA promoted by release.yml. Never use `latest`, a release
# branch name, or a tag prefix; the deploy workflow rejects anything
# that is not a SHA.
NAMESPACE=fotosintesis
APP_ENV=prod
IMAGE_REGISTRY=us-central1-docker.pkg.dev/example-project/fotosintesis
BACKEND_IMAGE_TAG=0000000000000000000000000000000000000000
FRONTEND_IMAGE_TAG=0000000000000000000000000000000000000000
BACKEND_REPLICAS=2
FRONTEND_REPLICAS=2
FRONTEND_SERVICE_TYPE=ClusterIP
FRONTEND_API_BASE_URL=http://fotosintesis-backend:8000
FRONTEND_SERVER_API_BASE_URL=http://fotosintesis-backend:8000
FRONTEND_EXPOSURE_MODE=hostname-https
FRONTEND_HOSTNAME=app.example.com
STATIC_IP_NAME=fotosintesis-prod-frontend-ip
MANAGED_CERTIFICATE_NAME=fotosintesis-prod-managed-cert
BACKEND_GCP_SERVICE_ACCOUNT_EMAIL=fotosintesis-backend-prod@example-project.iam.gserviceaccount.com
FRONTEND_GCP_SERVICE_ACCOUNT_EMAIL=fotosintesis-frontend-prod@example-project.iam.gserviceaccount.com
OBJECT_STORAGE_PROVIDER=gcs
OBJECT_STORAGE_BUCKET=example-fotosintesis-storage
CLOUD_SQL_INSTANCE_CONNECTION_NAME=example-project:us-central1:fotosintesis-prod
CLOUD_SQL_DATABASE_NAME=fotosintesis
CLOUD_SQL_PROXY_IMAGE=gcr.io/cloud-sql-connectors/cloud-sql-proxy:2.15.2
CLOUD_SQL_PROXY_PORT=5432
DATABASE_URL_SECRET_KEY=database-url
AUTH_SECRET_SECRET_KEY=auth-secret
EXTERNAL_SECRETS_STORE_NAME=fotosintesis-secret-store
EXTERNAL_SECRETS_REFRESH_INTERVAL=5m
GCP_PROJECT_ID=example-project
MODEL_PROVIDER=openai
VISION_PROVIDER=openai
JUDGE_PROVIDER=openai
SEARCH_PROVIDER=mock
EMBEDDING_PROVIDER=mock
MODEL_PROVIDERS='["openai","gemini"]'
VISION_PROVIDERS='["openai","gemini"]'
JUDGE_PROVIDERS='["openai","gemini"]'
SEARCH_PROVIDERS='["mock"]'
OPENAI_TEXT_MODEL=gpt-5.4
OPENAI_VISION_MODEL=gpt-5.4
OPENAI_JUDGE_MODEL=gpt-5.4
OPENAI_SEARCH_MODEL=gpt-5.4
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
GEMINI_TEXT_MODEL=gemini-2.5-flash
GEMINI_VISION_MODEL=gemini-2.5-flash
GEMINI_JUDGE_MODEL=gemini-2.5-flash
GEMINI_SEARCH_MODEL=gemini-2.5-flash
EMBEDDING_DIMENSION=8
RUNTIME_SECRET_NAME=fotosintesis-runtime
# AUTH_URL is derived by deploy.yml from FRONTEND_HOSTNAME;
# set a placeholder for manual rendering.
AUTH_URL=https://app.example.com
# Durable background jobs (worker enabled before the producer rollout)
JOBS_PRODUCER_ENABLED=false
JOBS_WORKER_ENABLED=true
JOBS_POLL_INTERVAL_SECONDS=5
JOBS_BATCH_SIZE=10
JOBS_WORKER_CONCURRENCY=5
JOBS_LEASE_DURATION_SECONDS=300
JOBS_LEASE_RENEWAL_INTERVAL_SECONDS=60
JOBS_MAX_ATTEMPTS_DEFAULT=3
JOBS_BACKOFF_BASE_SECONDS=10
JOBS_BACKOFF_CAP_SECONDS=3600
JOBS_SHUTDOWN_DRAIN_SECONDS=30
JOBS_METRICS_HOST=0.0.0.0
JOBS_METRICS_PORT=9100
JOBS_TERMINATION_GRACE_PERIOD_SECONDS=90
GKE_CLUSTER_PROJECT_ID=gke-project-id
GKE_CLUSTER_LOCATION=us-central1
GKE_CLUSTER_NAME=gke-cluster-name
