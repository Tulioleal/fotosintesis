# Copy to values.env and fill from `tofu output` for infra/opentofu/envs/dev.
NAMESPACE=fotosintesis
APP_ENV=dev
IMAGE_REGISTRY=us-central1-docker.pkg.dev/example-project/fotosintesis
BACKEND_IMAGE_TAG=latest
FRONTEND_IMAGE_TAG=latest
BACKEND_REPLICAS=1
FRONTEND_REPLICAS=1
FRONTEND_SERVICE_TYPE=ClusterIP
FRONTEND_API_BASE_URL=http://fotosintesis-backend:8000
BACKEND_GCP_SERVICE_ACCOUNT_EMAIL=fotosintesis-backend-dev@example-project.iam.gserviceaccount.com
FRONTEND_GCP_SERVICE_ACCOUNT_EMAIL=fotosintesis-frontend-dev@example-project.iam.gserviceaccount.com
OBJECT_STORAGE_BUCKET=example-fotosintesis-storage
CLOUD_SQL_INSTANCE_CONNECTION_NAME=example-project:us-central1:fotosintesis-dev
CLOUD_SQL_DATABASE_NAME=fotosintesis
MODEL_PROVIDER=mock
VISION_PROVIDER=mock
JUDGE_PROVIDER=mock
SEARCH_PROVIDER=mock
EMBEDDING_PROVIDER=mock
OPENAI_TEXT_MODEL=gpt-5.4
OPENAI_VISION_MODEL=gpt-5.4
OPENAI_JUDGE_MODEL=gpt-5.4
OPENAI_SEARCH_MODEL=gpt-5.4
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSION=8
RUNTIME_SECRET_NAME=fotosintesis-runtime
