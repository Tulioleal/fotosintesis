            "type": "string"
          },
          "password": {
            "minLength": 1,
            "title": "Password",
            "type": "string"
          }
        },
        "required": [
          "email",
          "password"
        ],
        "title": "CredentialsVerifyRequest",
        "type": "object"
      },
      "CredentialsVerifyResponse": {
        "properties": {
          "session_expires_at": {
