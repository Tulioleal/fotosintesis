{
  "name": "frontend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "openapi:export": "python3 ../backend/scripts/export_openapi.py src/lib/generated/openapi.json",
    "openapi:generate": "pnpm openapi:export && openapi-typescript src/lib/generated/openapi.json -o src/lib/generated/openapi.d.ts",
    "openapi:check": "pnpm openapi:generate && git diff --exit-code -- src/lib/generated/openapi.json src/lib/generated/openapi.d.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@auth/core": "^0.37.4",
    "@hookform/resolvers": "^3.9.1",
    "@phosphor-icons/react": "^2.1.10",
    "@tanstack/react-query": "^5.62.11",
    "next": "^15.1.3",
    "next-auth": "^5.0.0-beta.25",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.54.2",
    "sass": "^1.83.0",
    "zod": "^3.24.1",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@eslint/js": "9",
    "@next/eslint-plugin-next": "15.5.18",
    "@playwright/test": "^1.49.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@types/node": "^22.10.5",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@typescript-eslint/parser": "8",
    "eslint": "^9.17.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "jsdom": "^25.0.1",
    "openapi-typescript": "^7.13.0",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.62.0",
    "vitest": "^2.1.8"
  }
}
